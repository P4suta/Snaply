root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
csharp_prefer_braces = true:warning
dotnet_sort_system_directives_first = true
dotnet_style_readonly_field = true:warning
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_diagnostic.IDE0005.severity = suggestion
dotnet_diagnostic.CA1515.severity = warning
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA5392.severity = error

[*.g.cs]
generated_code = true

[*.g.i.cs]
generated_code = true

[obj/**]
generated_code = true

[*-AutoInitializer.cs]
generated_code = true

[tests/**.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA2000.severity = none
dotnet_diagnostic.CA1062.severity = none

[src/Snaply.App/App.xaml.cs]
dotnet_diagnostic.CA1515.severity = none

[src/Snaply.App/MainWindow.xaml.cs]
dotnet_diagnostic.CA1515.severity = none

[src/Snaply.App/MainPage.xaml.cs]
dotnet_diagnostic.CA1515.severity = none

[src/Snaply.App/ViewModels/MainViewModel.cs]
dotnet_diagnostic.CA1031.severity = none

[src/Snaply.App/ImageExportService.cs]
dotnet_diagnostic.CA1849.severity = none

[src/Snaply.App/ScreenCaptureService.cs]
dotnet_diagnostic.CA2000.severity = none
