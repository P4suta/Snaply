<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Snaply.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:Snaply.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Snaply"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HighContrastAdjustment="None"
    mc:Ignorable="d">

    <Grid>
        <!--  Canvas: the preview card with a persistent floating command bar.  -->
        <Border
            Margin="{StaticResource ContentPadding}"
            Style="{StaticResource PreviewSurfaceStyle}">
            <Grid>
                <Grid.Resources>
                    <!--  "Saved" feedback: the folder icon briefly flips to a green check that pops in,
                          holds, then flips back. Played by the code-behind on each successful auto-save.  -->
                    <Storyboard x:Name="SavedFeedback">
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FolderGlyph" Storyboard.TargetProperty="Opacity">
                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                            <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="0" />
                            <LinearDoubleKeyFrame KeyTime="0:0:0.9" Value="0" />
                            <LinearDoubleKeyFrame KeyTime="0:0:1.05" Value="1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SavedCheck" Storyboard.TargetProperty="Opacity">
                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                            <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="1" />
                            <LinearDoubleKeyFrame KeyTime="0:0:0.9" Value="1" />
                            <LinearDoubleKeyFrame KeyTime="0:0:1.05" Value="0" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SavedCheckScale" Storyboard.TargetProperty="ScaleX">
                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.6" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.28" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.44" Value="1" KeySpline="0.2,0,0,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SavedCheckScale" Storyboard.TargetProperty="ScaleY">
                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.6" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.28" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.44" Value="1" KeySpline="0.2,0,0,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </Grid.Resources>

                <!--  Ambient backdrop: a soft field of freely, gently shifting colour that fills the
                      WHOLE card — always on, so the captured image floats over a living background.
                      It calms (lower saturation, slower colour drift) while an image is shown.  -->
                <ctrl:AmbientBackdrop
                    x:Name="AmbientBackdrop"
                    IsActive="True"
                    IsMuted="{x:Bind ViewModel.HasImage, Mode=OneWay}" />

                <!--  The captured image shares the ambient's exact region (fills the whole card) so
                      zoom/pan crops at the card edge, never at an inset. It still reads as floating:
                      it's lifted with a drop shadow and the ambient shows through around it.  -->
                <ctrl:ZoomableImage x:Name="PreviewImageControl" />

                <!--  Only the floating UI (pills, error banner, progress) is inset from the card edge.  -->
                <Grid Padding="{StaticResource PreviewSurfacePadding}">

                <!--  Command pill, top-left: re-capture from here. Persistent so the shell is identical
                      before and after the first capture (the empty canvas is the ambient backdrop).  -->
                <Border
                    x:Name="CommandBar"
                    Margin="{StaticResource FloatingToolbarMargin}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource FloatingToolbarStyle}">
                    <SplitButton
                        x:Name="PrimaryCaptureButton"
                        AutomationProperties.AutomationId="PrimaryCaptureButton"
                        Command="{x:Bind ViewModel.PrimaryCaptureCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <FontIcon FontSize="{StaticResource IconSizeSmall}" Glyph="{x:Bind ViewModel.PrimaryCaptureGlyph, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.PrimaryCaptureLabel, Mode=OneWay}" />
                        </StackPanel>
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem
                                    x:Uid="CaptureFullScreenLabel"
                                    AutomationProperties.AutomationId="CaptureFullScreenItem"
                                    Command="{x:Bind ViewModel.SelectCaptureFullScreenCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE7B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Uid="CaptureRegionLabel"
                                    AutomationProperties.AutomationId="CaptureRegionItem"
                                    Command="{x:Bind ViewModel.SelectCaptureRegionCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xEF20;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Uid="CaptureWindowLabel"
                                    AutomationProperties.AutomationId="CaptureWindowItem"
                                    Command="{x:Bind ViewModel.SelectCaptureWindowCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE737;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                </Border>

                <!--  Open-folder pill, top-right (mirrors the Capture pill). Opens the captures folder;
                      on every auto-save its folder icon briefly flips to a green check — that animation
                      IS the "saved" feedback (no toast).  -->
                <Border
                    x:Name="OpenFolderBar"
                    Margin="{StaticResource FloatingToolbarMargin}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource FloatingToolbarStyle}">
                    <Button
                        x:Name="OpenFolderButton"
                        x:Uid="OpenFolderButton"
                        Padding="{StaticResource IconButtonPadding}"
                        AutomationProperties.AutomationId="OpenFolderButton"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnOpenFolderClick">
                        <Grid>
                            <FontIcon
                                x:Name="FolderGlyph"
                                FontSize="{StaticResource IconSizeSmall}"
                                Glyph="&#xE8B7;" />
                            <FontIcon
                                x:Name="SavedCheck"
                                FontSize="{StaticResource IconSizeSmall}"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                Glyph="&#xE73E;"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <ScaleTransform x:Name="SavedCheckScale" ScaleX="0.6" ScaleY="0.6" />
                                </FontIcon.RenderTransform>
                            </FontIcon>
                        </Grid>
                    </Button>
                </Border>

                <!--  Prominent, dismissible error surface (bottom). Friendly title up top; raw technical
                      detail (code + exception) tucked into the details expander with a copy button.  -->
                <InfoBar
                    x:Name="ErrorInfoBar"
                    Margin="{StaticResource ContentPadding}"
                    VerticalAlignment="Bottom"
                    AutomationProperties.AutomationId="ErrorInfoBar"
                    IsOpen="{x:Bind ViewModel.IsErrorOpen, Mode=TwoWay}"
                    Severity="Error"
                    Title="{x:Bind ViewModel.ErrorTitle, Mode=OneWay}">
                    <InfoBar.Content>
                        <Expander
                            x:Uid="ErrorDetailsExpander"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch">
                            <StackPanel Spacing="{StaticResource SpacingSmall}">
                                <TextBlock
                                    AutomationProperties.AutomationId="ErrorDetailText"
                                    IsTextSelectionEnabled="True"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.ErrorDetail, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                                <Button
                                    x:Name="CopyErrorDetailButton"
                                    x:Uid="ErrorCopyButton"
                                    AutomationProperties.AutomationId="CopyErrorDetailButton"
                                    Click="OnCopyErrorDetailClick" />
                            </StackPanel>
                        </Expander>
                    </InfoBar.Content>
                </InfoBar>

                <ProgressRing
                    Width="{StaticResource ProgressRingSize}"
                    Height="{StaticResource ProgressRingSize}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
