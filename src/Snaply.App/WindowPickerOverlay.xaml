<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Snaply.WindowPickerOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Snaply"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Background="#01000000"
        IsTabStop="True"
        KeyDown="OnKeyDown"
        PointerMoved="OnPointerMoved"
        PointerPressed="OnPointerPressed"
        PointerReleased="OnPointerReleased">

        <!--  Frozen screenshot of every monitor, each positioned in virtual-desktop DIP space  -->
        <Canvas x:Name="BackdropCanvas" />

        <!--  Dim scrim so the highlighted window reads as "the bright bit"  -->
        <Border Background="{StaticResource CaptureScrimBrush}" />

        <!--  Highlight rectangle + title badge for the window under the cursor  -->
        <Canvas x:Name="HighlightCanvas">
            <Rectangle
                x:Name="HighlightRect"
                Fill="{StaticResource SelectionFillBrush}"
                Stroke="{ThemeResource SystemAccentColorLight2}"
                StrokeThickness="{StaticResource SelectionStrokeThickness}"
                Visibility="Collapsed" />
            <Border
                x:Name="TitleBadge"
                Padding="{StaticResource HintBubblePadding}"
                Background="{StaticResource HintBubbleBackgroundBrush}"
                CornerRadius="{StaticResource OverlayCornerRadius}"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="TitleText"
                    Foreground="{StaticResource HintBubbleForegroundBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    TextTrimming="CharacterEllipsis" />
            </Border>
        </Canvas>

        <!--  Hint  -->
        <Border
            Margin="{StaticResource HintBubbleMargin}"
            Padding="{StaticResource HintBubblePadding}"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{StaticResource HintBubbleBackgroundBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}">
            <TextBlock
                x:Uid="WindowPickerHint"
                Foreground="{StaticResource HintBubbleForegroundBrush}"
                Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Border>
    </Grid>
</Window>
