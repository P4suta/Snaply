<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Snaply.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    DefaultButton="Close"
    mc:Ignorable="d">

    <ScrollViewer
        MaxHeight="{StaticResource SettingsScrollMaxHeight}"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Width="{StaticResource SidePanelWidth}" Spacing="{StaticResource SpacingLarge}">

            <!--  ===== General ===== -->
            <TextBlock x:Uid="SectionGeneral" Style="{StaticResource SectionHeaderTextStyle}" />
            <StackPanel Spacing="{StaticResource SpacingXSmall}">
                <controls:SettingsCard x:Uid="CardTheme" HeaderIcon="{ui:FontIcon Glyph=&#xE771;}">
                    <controls:Segmented
                        x:Name="ThemeSegmented"
                        AutomationProperties.AutomationId="ThemeSegmented"
                        SelectionChanged="OnThemeSelectionChanged">
                        <controls:SegmentedItem x:Uid="ThemeSystem" />
                        <controls:SegmentedItem x:Uid="ThemeLight" />
                        <controls:SegmentedItem x:Uid="ThemeDark" />
                    </controls:Segmented>
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="CardLanguage" HeaderIcon="{ui:FontIcon Glyph=&#xE774;}">
                    <ComboBox
                        x:Name="LanguageComboBox"
                        MinWidth="{StaticResource InlineSliderWidth}"
                        AutomationProperties.AutomationId="LanguageComboBox"
                        SelectionChanged="OnLanguageSelectionChanged" />
                </controls:SettingsCard>
            </StackPanel>

            <!--  ===== Beautify ===== -->
            <TextBlock x:Uid="SectionBeautify" Style="{StaticResource SectionHeaderTextStyle}" />
            <StackPanel Spacing="{StaticResource SpacingXSmall}">
                <controls:SettingsCard x:Uid="CardBackground" HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox
                        x:Name="BackgroundComboBox"
                        MinWidth="{StaticResource InlineSliderWidth}"
                        AutomationProperties.AutomationId="BackgroundComboBox"
                        DisplayMemberPath="Name"
                        ItemsSource="{x:Bind ViewModel.BackgroundPresets}"
                        SelectedIndex="{x:Bind ViewModel.SelectedBackgroundIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="CardShadow" HeaderIcon="{ui:FontIcon Glyph=&#xE81E;}">
                    <ToggleSwitch
                        x:Name="ShadowToggle"
                        MinWidth="0"
                        AutomationProperties.AutomationId="ShadowToggle"
                        IsOn="{x:Bind ViewModel.ShadowEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    x:Uid="CardAspect"
                    ContentAlignment="Vertical"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE799;}">
                    <controls:Segmented
                        x:Name="AspectSegmented"
                        x:Uid="SegAspect"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.AutomationId="AspectComboBox"
                        SelectedIndex="{x:Bind ViewModel.SelectedAspectIndex, Mode=TwoWay}">
                        <controls:SegmentedItem x:Uid="AspectAuto" />
                        <controls:SegmentedItem x:Uid="AspectSquare" />
                        <controls:SegmentedItem x:Uid="AspectFourThree" />
                        <controls:SegmentedItem x:Uid="AspectSixteenNine" />
                    </controls:Segmented>
                </controls:SettingsCard>
            </StackPanel>

            <!--  ===== Capture ===== -->
            <TextBlock x:Uid="SectionCapture" Style="{StaticResource SectionHeaderTextStyle}" />
            <controls:SettingsCard x:Uid="CardHide" HeaderIcon="{ui:FontIcon Glyph=&#xE7B3;}">
                <ToggleSwitch
                    x:Name="HideOnCaptureToggle"
                    MinWidth="0"
                    AutomationProperties.AutomationId="HideOnCaptureToggle"
                    IsOn="{x:Bind ViewModel.HideOnCapture, Mode=TwoWay}" />
            </controls:SettingsCard>

            <!--  ===== Diagnostics (tucked into an expander) ===== -->
            <controls:SettingsExpander x:Uid="ExpanderDiagnostics" HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}">
                <TextBlock
                    x:Name="AppInfoText"
                    AutomationProperties.AutomationId="AppInfoText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextAlignment="Right" />
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard x:Uid="CardLogs">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <Button
                                x:Name="OpenLogsButton"
                                x:Uid="OpenLogsButton"
                                AutomationProperties.AutomationId="OpenLogsButton"
                                Click="OnOpenLogsClick" />
                            <Button
                                x:Name="CopyDiagnosticsButton"
                                x:Uid="CopyDiagnosticsButton"
                                AutomationProperties.AutomationId="CopyDiagnosticsButton"
                                Click="OnCopyDiagnosticsClick" />
                        </StackPanel>
                    </controls:SettingsCard>

                    <controls:SettingsCard x:Uid="CardVerboseLogging">
                        <ToggleSwitch
                            x:Name="VerboseLoggingToggle"
                            MinWidth="0"
                            AutomationProperties.AutomationId="VerboseLoggingToggle"
                            Toggled="OnVerboseLoggingToggled" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
