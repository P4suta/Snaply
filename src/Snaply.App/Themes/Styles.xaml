<?xml version="1.0" encoding="utf-8" ?>
<!--
    Control styles + named brushes, driven by the design tokens. Colours stay on
    Fluent {ThemeResource} brushes (no hardcoded colour at a usage site);
    dimensions reference {StaticResource} tokens. Merged after the token
    dictionaries AND after XamlControlsResources (whose type-ramp styles these
    derive from) so every StaticResource resolves.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ===== Editor surfaces =====  -->

    <!--  The preview canvas: a Fluent layer surface that frames the beautified
          image (or the empty state). Deeper than a card so the image reads as the
          document under edit.  -->
    <!--  No Padding here: the ambient backdrop fills the whole card, and only the content
          (image + floating pills) is inset — the inner content Grid carries PreviewSurfacePadding.  -->
    <Style x:Key="PreviewSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource SurfaceBorderThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
        <Setter Property="MinWidth" Value="{StaticResource PreviewMinWidth}" />
        <Setter Property="MinHeight" Value="{StaticResource PreviewMinHeight}" />
    </Style>

    <!--  Content-hosted action toolbar that floats over the top of the preview
          (capture + save + copy). Same layer-surface language as the zoom controls
          so the two floating clusters read as a family.  -->
    <Style x:Key="FloatingToolbarStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource SurfaceBorderThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource FloatingToolbarPadding}" />
    </Style>

    <!--  Section label above a group of SettingsCards.  -->
    <Style
        x:Key="SectionHeaderTextStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <!--  Live numeric value beside an in-card slider (right-aligned, tabular).  -->
    <Style
        x:Key="SliderValueTextStyle"
        BasedOn="{StaticResource CaptionTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="MinWidth" Value="{StaticResource SliderValueMinWidth}" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--  ===== Region-overlay brushes (declared once, no inline literals) =====
          These sit over a frozen screenshot, so they are deliberately theme-
          invariant rather than Fluent theme brushes: the scrim must dim and the
          hint bubble must stay legible on arbitrary captured content. The
          selection stroke itself uses SystemAccentColor* at the usage site.  -->
    <SolidColorBrush
        x:Key="CaptureScrimBrush"
        Opacity="0.4"
        Color="Black" />
    <SolidColorBrush
        x:Key="SelectionFillBrush"
        Opacity="0.13"
        Color="White" />
    <SolidColorBrush
        x:Key="HintBubbleBackgroundBrush"
        Opacity="0.8"
        Color="Black" />
    <SolidColorBrush x:Key="HintBubbleForegroundBrush" Color="White" />
</ResourceDictionary>
