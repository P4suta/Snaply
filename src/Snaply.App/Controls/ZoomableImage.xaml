<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Snaply.Controls.ZoomableImage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Snaply.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Transparent background so pointer events (wheel / drag) fire over empty areas too.  -->
    <Grid
        x:Name="Viewport"
        Background="Transparent"
        DoubleTapped="OnDoubleTapped"
        PointerCanceled="OnPointerReleased"
        PointerMoved="OnPointerMoved"
        PointerPressed="OnPointerPressed"
        PointerReleased="OnPointerReleased"
        PointerWheelChanged="OnPointerWheelChanged"
        SizeChanged="OnViewportSizeChanged">

        <!--  Zoom/pan are driven by Composition (element Scale/Offset) for GPU-smooth motion.
              Centred + capped at the image's native size (set in code): a capture smaller than the
              viewport shows at 100% instead of being upscaled, and the element wraps the content
              tightly (no letterbox), which keeps panning symmetric on both axes.  -->
        <Image
            x:Name="DisplayImage"
            x:Uid="PreviewImage"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            AutomationProperties.AutomationId="PreviewImage"
            Stretch="Uniform">
            <!--  Lifts the image off the ambient backdrop so it reads as floating. The Z depth that
                  drives it is written with the pan/zoom Translation in code-behind.  -->
            <Image.Shadow>
                <ThemeShadow />
            </Image.Shadow>
        </Image>
    </Grid>
</UserControl>
