<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Snaply.RegionOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Snaply"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Background="#01000000"
        IsTabStop="True"
        KeyDown="OnKeyDown"
        PointerMoved="OnPointerMoved"
        PointerPressed="OnPointerPressed"
        PointerReleased="OnPointerReleased">

        <!--  Frozen screenshot of every monitor, each positioned in virtual-desktop DIP space  -->
        <Canvas x:Name="BackdropCanvas" />

        <!--  Dim scrim so the selection reads as "the bright bit"  -->
        <Border Background="{StaticResource CaptureScrimBrush}" />

        <!--  Selection rectangle lives on this canvas  -->
        <Canvas x:Name="SelectionCanvas">
            <Rectangle
                x:Name="SelectionRect"
                Fill="{StaticResource SelectionFillBrush}"
                Stroke="{ThemeResource SystemAccentColorLight2}"
                StrokeThickness="{StaticResource SelectionStrokeThickness}"
                Visibility="Collapsed" />
        </Canvas>

        <!--  Hint  -->
        <Border
            Margin="{StaticResource HintBubbleMargin}"
            Padding="{StaticResource HintBubblePadding}"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{StaticResource HintBubbleBackgroundBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}">
            <TextBlock
                x:Uid="RegionHint"
                Foreground="{StaticResource HintBubbleForegroundBrush}"
                Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Border>
    </Grid>
</Window>
